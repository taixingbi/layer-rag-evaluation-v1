# Local dev: copy to .env and fill in values.
# GitHub Actions: set the same names as repository secrets (Settings → Secrets and variables → Actions).

# Required for run_eval (POST /v1/rag/query — no /v1 suffix on RAG_BASE_URL)
RAG_BASE_URL=
RAG_COLLECTION_BASE=

# Gold generator optional LLM must_contain extraction (--enable-must-contain-llm)
# CHAT_BASE_URL=
# INFERENCE_URL=
# CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct
# INFERENCE_MODEL=Qwen/Qwen2.5-7B-Instruct
# CHAT_API_KEY=
